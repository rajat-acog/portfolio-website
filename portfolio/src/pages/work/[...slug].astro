---
import { getCollection, getEntry } from 'astro:content';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

// ✅ Generate routes from portfolios
export async function getStaticPaths() {
	const profiles = await getCollection('portfolios');

	return profiles.map((entry) => ({
		params: { slug: entry.id },
	}));
}

// ✅ Get slug from URL
const { slug } = Astro.params;

// ✅ Fetch correct MD file dynamically
const entry = await getEntry('portfolios', slug);

// ❗ Safety check
if (!entry) {
	throw new Error(`No portfolio found for slug: ${slug}`);
}

// ✅ Extract data from MD
const {
	hero,
	summary,
	projects = [],
} = entry.data;
---

<BaseLayout title={hero?.title} description={hero?.tagline}>
	<div class="stack gap-20">

		<!-- HEADER -->
		<header class="header wrapper stack gap-4">
			<a class="back-link" href={`/portfolio/${slug}`}>
				<Icon icon="arrow-left" /> Back to Portfolio
			</a>

			<Hero title={hero?.title} tagline={hero?.tagline} align="start">
				<div class="details">
					{summary && (
						<p class="description">{summary}</p>
					)}
				</div>
			</Hero>
		</header>

		<!-- PROJECTS -->
		<main class="wrapper">
			<div class="projects">

				{projects.length > 0 ? (
					projects.map((project) => (
						<div class="project-card">

							<h3 class="project-title">{project.name}</h3>

							{project.tech?.length > 0 && (
								<div class="tech-section">
									<p class="label">Tech Stack</p>
									<div class="tags">
										{project.tech.map((tech) => (
											<Pill>{tech}</Pill>
										))}
									</div>
								</div>
							)}

							<div class="links">
								{project.frontend && (
									<a href={project.frontend} target="_blank" class="btn-link">
										🌐 Live App
									</a>
								)}

								{project.backend && (
									<a href={project.backend} target="_blank" class="btn-link secondary">
										⚙️ API / Backend
									</a>
								)}
							</div>

						</div>
					))
				) : (
					<p>No projects found.</p>
				)}

			</div>
		</main>

		<ContactCTA />

	</div>
</BaseLayout>

<style>
.header {
	margin-top: 1rem;
	padding-bottom: 2rem;
	border-bottom: 1px solid var(--gray-800);
}

.back-link {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
	text-decoration: none;
	font-size: var(--text-sm);
	color: var(--gray-400);
}

.back-link:hover {
	color: var(--gray-0);
}

.description {
	font-size: var(--text-md);
	max-width: 60ch;
	line-height: 1.6;
	color: var(--gray-300);
}

.projects {
	display: grid;
	gap: 1.8rem;
	margin-top: 2rem;
}

.project-card {
	padding: 1.5rem;
	border-radius: 1rem;
	border: 1px solid var(--gray-800);
	background: var(--gradient-subtle);
	box-shadow: var(--shadow-sm);
	transition: transform 0.2s ease;
}

.project-card:hover {
	transform: translateY(-4px);
}

.project-title {
	font-size: var(--text-lg);
	margin-bottom: 0.5rem;
}

.tags {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin: 0.6rem 0;
}

.links {
	display: flex;
	gap: 0.6rem;
	margin-top: 0.5rem;
}

.btn-link {
	padding: 0.35rem 0.7rem;
	border-radius: 0.4rem;
	font-size: var(--text-xs);
	text-decoration: none;
	background: var(--accent-regular);
	color: var(--accent-text-over);
}

.btn-link.secondary {
	background: var(--gray-700);
	color: var(--gray-100);
}

.btn-link:hover {
	opacity: 0.9;
}

@media (min-width: 50em) {
	.projects {
		grid-template-columns: repeat(2, 1fr);
	}
}
</style>