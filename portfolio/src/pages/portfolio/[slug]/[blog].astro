  }

  /* ================= INLINE CODE ================= */
  :global(.blog-content code) {
    background: rgba(255,255,255,0.06);
    padding: 0.2rem 0.45rem;
    border-radius: 0.3rem;

    font-size: 0.85rem;
    color: #ffb86c;
  }

  /* ================= CODE BLOCK ================= */
  :global(.blog-content pre) {
    margin: 2rem 0;
    padding: 1.1rem;

