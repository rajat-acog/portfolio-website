---
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import { marked } from 'marked';
import { getCollection } from 'astro:content';

import ContactCTA from '../../../components/ContactCTA.astro';
import Hero from '../../../components/Hero.astro';
import Icon from '../../../components/Icon.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

// ✅ CONFIG
const OWNER = "aganitha";
const REPO = "tech-coe";

// ==============================
// ✅ PATHS
// ==============================
export async function getStaticPaths() {
  const base = './src/content/portfolios';
  const users = fs.readdirSync(base);

  const paths = [];

  for (const user of users) {
    const userDir = path.join(base, user);
    if (!fs.statSync(userDir).isDirectory()) continue;

    const files = fs.readdirSync(userDir);

    files
      .filter((f) => f.endsWith('.md'))
      .forEach((file) => {
        paths.push({
          params: {
            slug: user,
            blog: file.replace('.md', ''),
          },
        });
      });
  }

  return paths;
}

// ==============================
// ✅ PARAMS
// ==============================
const { slug, blog } = Astro.params;

// ==============================
// ✅ READ FILE
// ==============================
const filePath = path.join(
  'src/content/portfolios',
  slug,
  `${blog}.md`
);

const file = fs.readFileSync(filePath, 'utf-8');
const { data, content } = matter(file);

// ==============================
// 🔥 FETCH CONTRIBUTORS
// ==============================
const githubFilePath = `src/content/portfolios/${slug}/${blog}.md`;

let contributors = [];

try {
  const res = await fetch(
    `https://api.github.com/repos/${OWNER}/${REPO}/commits?path=${githubFilePath}`
  );

  const commits = await res.json();

  contributors = [
    ...new Map(
      commits.map((c) => [
        c.author?.login,
        {
          username: c.author?.login,
          avatar: c.author?.avatar_url,
          url: c.author?.html_url,
        },
      ])
    ).values(),
  ];
} catch (err) {
  console.error("GitHub API failed:", err);
}

// ==============================
// 🔥 NORMALIZE + MAP
// ==============================
const normalize = (u) => u?.split('-')[0]?.toLowerCase();

const allProfiles = await getCollection('portfolios');

const finalContributors = contributors
  .map((c) => {
    const slugMatch = normalize(c.username);

    const profile = allProfiles.find((p) =>
      p.id.split('/')[0].toLowerCase() === slugMatch
    );

    return {
      ...c,
      slug: slugMatch,
      isInternal: !!profile,
    };
  })
  .filter((c) => c.slug !== slug);

// ==============================
// 🔥 MARKDOWN
// ==============================
const headings = [];

const processedContent = content.replace(/^##\s(.+)/gm, (_, title) => {
  const id = title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
  headings.push({ title, id });
  return `## ${title}\n<span id="${id}"></span>`;
});

const html = marked.parse(processedContent);
---

<BaseLayout title={data.title}>
  <div class="page">

    <!-- HEADER -->
    <header class="header wrapper">
      <a class="back-link" href={`/portfolio/${slug}`}>
        <Icon icon="arrow-left" /> Back to Profile
      </a>

      <div class="blog-header">
  <Hero title={data.title} tagline={`By ${data.author}`} align="start" />

  <!-- 👥 INLINE CONTRIBUTORS -->
  <div class="contributors-inline">
    {
      finalContributors.length > 0 ? (
        <div class="avatars">
          {finalContributors.map((c) => (
            <a
              href={c.isInternal ? `/portfolio/${c.slug}` : c.url}
              target="_blank"
              class="avatar"
              title={c.username}  <!-- tooltip -->
            >
              {c.avatar ? (
                <img src={c.avatar} alt={c.username} />
              ) : (
                <span>{c.username?.charAt(0).toUpperCase()}</span>
              )}
            </a>
          ))}
        </div>
      ) : (
        <span class="muted">No other contributors</span>
      )
    }
  </div>
</div>
    </header>

    <!-- BODY -->
    <div class="layout wrapper">

      <!-- SIDEBAR -->
      <aside class="sidebar">
        <div class="sidebar-inner">
          <h4>On this page</h4>
          <ul>
            {headings.map((h) => (
              <li>
                <a href={`#${h.id}`}>{h.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="content">

        <article class="blog-content" set:html={html}></article>

        <!-- 🔥 CONTRIBUTORS -->
        {finalContributors.length > 0 && (
          <section class="contributors">
            <h3>Contributors</h3>

            <div class="contributors-grid">
              {finalContributors.map((c) => (
                <a
                  href={c.isInternal ? `/portfolio/${c.slug}` : c.url}
                  target="_blank"
                  class="contributor-card"
                >
                  {c.avatar ? (
                    <img src={c.avatar} alt={c.username} />
                  ) : (
                    <div class="avatar-fallback">
                      {c.username?.charAt(0).toUpperCase()}
                    </div>
                  )}

                  <div class="meta">
                    <p class="name">{c.username}</p>
                    <span class={`tag ${c.isInternal ? "internal" : "external"}`}>
                      {c.isInternal ? "Profile" : "GitHub"}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

      </main>

    </div>

    <ContactCTA />

  </div>
</BaseLayout>

<style>
/* LAYOUT */
.layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 2.5rem;
  margin-top: 3rem;
}

/* SIDEBAR */
.sidebar-inner {
  position: sticky;
  top: 100px;
  padding: 1.2rem;
  border-radius: 1rem;
  border: 1px solid var(--gray-800);
  background: var(--gradient-subtle);
}

.sidebar h4 {
  margin-bottom: 1rem;
  font-size: var(--text-sm);
  color: var(--gray-400);
}

.sidebar ul {
  list-style: none;
  padding: 0;
}

.sidebar li {
  margin-bottom: 0.6rem;
}

.sidebar a {
  text-decoration: none;
  font-size: var(--text-sm);
  color: var(--gray-400);
  transition: all 0.2s ease;
}

.sidebar a:hover {
  color: var(--accent-regular);
  transform: translateX(3px);
}

/* CONTENT */
.content {
  background: var(--gradient-subtle);
  border: 1px solid var(--gray-800);
  border-radius: 1.5rem;
  padding: 2.5rem;
  box-shadow: var(--shadow-md);
}

.blog-content {
  max-width: 70ch;
  line-height: 1.9;
  font-size: var(--text-md);
  color: var(--gray-200);
}

.blog-content h2 {
  margin-top: 3rem;
  margin-bottom: 1rem;
  border-bottom: 1px solid var(--gray-800);
}

.blog-content p {
  margin-bottom: 1.5rem;
}

/* CONTRIBUTORS */
.contributors {
  margin-top: 4rem;
}

.contributors-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
}

.contributor-card {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  padding: 0.8rem;
  border-radius: 0.8rem;
  border: 1px solid var(--gray-800);
  background: var(--gradient-subtle);
  text-decoration: none;
  color: inherit;
}

.contributor-card img,
.avatar-fallback {
  width: 45px;
  height: 45px;
  border-radius: 50%;
}

/* MOBILE */
@media (max-width: 900px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }

  .content {
    padding: 1.5rem;
  }
}

.blog-header {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

/* INLINE CONTRIBUTORS */
.contributors-inline {
  margin-top: -0.5rem;
}

/* AVATAR GROUP */
.avatars {
  display: flex;
  align-items: center;
}

/* EACH AVATAR */
.avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;

  display: flex;
  align-items: center;
  justify-content: center;

  background: var(--accent-regular);
  color: white;
  font-size: 0.7rem;
  font-weight: 600;

  border: 2px solid var(--gray-900);
  margin-left: -6px; /* overlap effect */

  text-decoration: none;
  transition: transform 0.2s ease;
}

.avatar:first-child {
  margin-left: 0;
}

.avatar:hover {
  transform: scale(1.1);
  z-index: 2;
}

/* IMAGE INSIDE */
.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* EMPTY STATE */
.muted {
  font-size: 0.8rem;
  color: var(--gray-500);
}
</style>