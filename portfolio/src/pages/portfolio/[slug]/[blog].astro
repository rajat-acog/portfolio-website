  }

  :global(.blog-content h3) {
    font-size: 1.2rem;
    font-weight: 600;

    margin: 1.6rem 0 0.4rem;

    color: var(--gray-100);
  }

  /* ================= PARAGRAPH ================= */
  :global(.blog-content p) {
    margin-bottom: 1.2rem;
  }

  /* ================= LINKS ================= */
  :global(.blog-content a) {
    color: var(--accent-regular);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: 0.2s;
  }

  :global(.blog-content a:hover) {
    border-bottom: 1px solid var(--accent-regular);
  }

  /* ================= LIST ================= */
  :global(.blog-content ul),
  :global(.blog-content ol) {
    padding-left: 1.4rem;
    margin-bottom: 1.2rem;
  }

  :global(.blog-content li) {
    margin-bottom: 0.35rem;
  }

  /* ================= BLOCKQUOTE ================= */
  :global(.blog-content blockquote) {
    margin: 1.8rem 0;
    padding: 1rem 1.2rem;

    border-left: 3px solid var(--accent-regular);

    background: rgba(255,255,255,0.03);

    border-radius: 0.5rem;
