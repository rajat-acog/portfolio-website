---
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import { marked } from 'marked';
import { getCollection } from 'astro:content';

import ContactCTA from '../../../components/ContactCTA.astro';
import Hero from '../../../components/Hero.astro';
import Icon from '../../../components/Icon.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

// ✅ CONFIG
const OWNER = "rajat-acog";
const REPO = "portfolio-website";

// ==============================
// ✅ PATHS
// ==============================
export async function getStaticPaths() {
  const base = './src/content/portfolios';
  const users = fs.readdirSync(base);

  const paths = [];

  for (const user of users) {
    const userDir = path.join(base, user);
    if (!fs.statSync(userDir).isDirectory()) continue;

    const files = fs.readdirSync(userDir);

    files
      .filter((f) => f.endsWith('.md'))
      .forEach((file) => {
        paths.push({
          params: {
            slug: user,
            blog: file.replace('.md', ''),
          },
        });
      });
  }

  return paths;
}

// ==============================
// ✅ PARAMS
// ==============================
const { slug, blog } = Astro.params;

// ==============================
// ✅ READ FILE
// ==============================
const filePath = path.join(
  'src/content/portfolios',
  slug,
  `${blog}.md`
);

const file = fs.readFileSync(filePath, 'utf-8');
const { data, content } = matter(file);

// ==============================
// 🔥 FETCH CONTRIBUTORS (FIXED)
// ==============================
const githubFilePath = `portfolio/src/content/portfolios/${slug}/${blog}.md`;

let contributors = [];

try {
  const res = await fetch(
    `https://api.github.com/repos/${OWNER}/${REPO}/commits?path=${githubFilePath}`
  );

  const githubData = await res.json();

  if (Array.isArray(githubData)) {
  contributors = [
    ...new Map(
      githubData
        .filter((c) => c.author?.login && c.author?.login !== "web-flow")
        .map((c) => [
          c.author.login,
          {
            username: c.author.login,
            avatar: c.author.avatar_url,
            url: c.author.html_url,
          },
        ])
    ).values(),
  ];
} else {
    console.error("GitHub API error:", githubData);
  }

} catch (err) {
  console.error("GitHub fetch failed:", err);
}

// ==============================
// 🔥 MATCH WITH LOCAL PROFILES
// ==============================
const allProfiles = await getCollection('portfolios');

const finalContributors = contributors
  .map((c) => {
    const username = c.username.toLowerCase();

    const profile = allProfiles.find((p) =>
      p.id.split('/')[0].toLowerCase() === username
    );

    return {
      ...c,
      slug: username,
      isInternal: !!profile,
    };
  })
  .filter((c) => {
  // only remove if there are multiple contributors
  if (contributors.length > 1) {
    return c.slug !== slug;
  }
  return true;
});

// ==============================
// 🔥 MARKDOWN
// ==============================
const headings = [];

const processedContent = content.replace(/^##\s(.+)/gm, (_, title) => {
  const id = title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
  headings.push({ title, id });
  return `## ${title}\n<span id="${id}"></span>`;
});

const html = marked.parse(processedContent);

console.log("Contributors:", contributors);
console.log("Final:", finalContributors);

---

<BaseLayout title={data.title}>
  <div class="page">

    <!-- HEADER -->
    <header class="header wrapper">
      <a class="back-link" href={`/portfolio/${slug}`}>
        <Icon icon="arrow-left" /> Back to Profile
      </a>

      <div class="blog-header">
        <Hero title={data.title} tagline={`By ${data.author}`} align="start" />

        <!-- 👇 INLINE CONTRIBUTORS -->
        <div class="contributors-inline">
  {
    finalContributors.length > 0 ? (
      <div class="contributors-mini">
        <span class="label">Contributors:</span>

        <div class="contributors-list">
          {finalContributors.map((c) => (
            <a
              href={c.isInternal ? `/portfolio/${c.slug}` : c.url}
              target="_blank"
              class="contributor-item"
              title={c.username}
            >
              {c.avatar ? (
                <img src={c.avatar} alt={c.username} />
              ) : (
                <span class="fallback">
                  {c.username.charAt(0).toUpperCase()}
                </span>
              )}

              <span class="name">{c.username}</span>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <span class="muted">No other contributors</span>
    )
  }
</div>
      </div>
    </header>

    <!-- BODY -->
    <div class="layout wrapper">

      <!-- SIDEBAR -->
      <aside class="sidebar">
        <div class="sidebar-inner">
          <h4>On this page</h4>
          <ul>
            {headings.map((h) => (
              <li>
                <a href={`#${h.id}`}>{h.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="content">
        <article class="blog-content" set:html={html}></article>
      </main>

    </div>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
.layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 2.5rem;
  margin-top: 3rem;
}

.sidebar-inner {
  position: sticky;
  top: 100px;
  padding: 1.2rem;
  border-radius: 1rem;
  border: 1px solid var(--gray-800);
  background: var(--gradient-subtle);
}

.sidebar a {
  text-decoration: none;
  font-size: var(--text-sm);
  color: var(--gray-400);
}

.sidebar a:hover {
  color: var(--accent-regular);
}

.content {
  background: var(--gradient-subtle);
  border: 1px solid var(--gray-800);
  border-radius: 1.5rem;
  padding: 2.5rem;
}

.blog-header {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.contributors-inline {
  margin-top: -0.5rem;
}

.avatars {
  display: flex;
}

.avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  overflow: hidden;
  margin-left: -6px;
  border: 2px solid var(--gray-900);
}

.avatar:first-child {
  margin-left: 0;
}

.avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.muted {
  font-size: 0.8rem;
  color: var(--gray-500);
}

@media (max-width: 900px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }
}

/* MINI CONTRIBUTORS */
.contributors-mini {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-top: -0.4rem;
  flex-wrap: wrap;
}

.label {
  font-size: 0.75rem;
  color: var(--gray-500);
}

/* LIST */
.contributors-list {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

/* ITEM */
.contributor-item {
  display: flex;
  align-items: center;
  gap: 0.35rem;

  padding: 0.2rem 0.5rem;
  border-radius: 999px;

  background: var(--gray-900);
  border: 1px solid var(--gray-800);

  text-decoration: none;
  color: var(--gray-300);

  font-size: 0.7rem;

  transition: all 0.2s ease;
}

.contributor-item:hover {
  background: var(--gray-800);
  color: white;
}

/* AVATAR */
.contributor-item img,
.fallback {
  width: 18px;
  height: 18px;
  border-radius: 50%;

  object-fit: cover;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 0.6rem;
  font-weight: 600;

  background: var(--accent-regular);
  color: white;
}

/* NAME */
.name {
  white-space: nowrap;
}
</style>