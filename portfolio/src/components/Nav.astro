---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';


const isCurrentPage = (href) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
  if (!pathname.startsWith('/')) pathname = '/' + pathname;
  if (!pathname.endsWith('/')) pathname += '/';
  return pathname === href || (href !== '/' && pathname.startsWith(href));
};

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
	{ label: 'Twitter', href: '#', icon: 'twitter-logo' },
	{ label: 'Twitch', href: '#', icon: 'twitch-logo' },
	{ label: 'GitHub', href: '#', icon: 'github-logo' },
	{ label: 'CodePen', href: '#', icon: 'codepen-logo' },
	{ label: 'dribbble', href: '#', icon: 'dribbble-logo' },
	{ label: 'YouTube', href: '#', icon: 'youtube-logo' },
];
---

<nav>
  <!-- LEFT -->
  <div class="menu-header">
    <a href="/" class="site-title">
      <Icon icon="terminal-window" size="1.6em" />
      Aganitha Cognitive Solutions
    </a>
  </div>

  <!-- CENTER -->
  <div class="nav-center">
    <ul class="nav-items">
      <li>
        <a href="/" class="link" aria-current={isCurrentPage('/') ? 'page' : null}>
          Home
        </a>
      </li>

      <li class="search-item">
        <button class="link search-trigger">🔍 Search</button>

        <!-- INLINE SEARCH -->
        <div class="search-inline">
          <input type="text" id="search-input" placeholder="Search..." />
          <button class="search-close">✕</button>
        </div>
      </li>
    </ul>

    <!-- RESULTS -->
    <div id="search-results"></div>
  </div>

  <!-- RIGHT -->
  <div class="menu-footer">
    <div class="socials">
				{
					iconLinks.map(({ href, icon, label }) => (
						<a href={href} class="social">
							<span class="sr-only">{label}</span>
							<Icon icon={icon} />
						</a>
					))
				}
			</div>
    <ThemeToggle />
  </div>
</nav>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">

<script type="module">
import * as pagefind from "/pagefind/pagefind.js";

document.addEventListener("DOMContentLoaded", async () => {
  const nav = document.querySelector("nav");
  const open = document.querySelector(".search-trigger");
  const close = document.querySelector(".search-close");
  const input = document.getElementById("search-input");
  const results = document.getElementById("search-results");

  await pagefind.init();

  open.addEventListener("click", () => {
    nav.classList.add("search-open");
    setTimeout(() => input.focus(), 100);
  });

  close.addEventListener("click", () => {
  // clear results immediately
  input.value = "";
  results.innerHTML = "";

  // wait for animation before removing class
  setTimeout(() => {
    nav.classList.remove("search-open");
  }, 150);
});

  input.addEventListener("input", async () => {
    const query = input.value.trim();

    if (!query) {
      results.innerHTML = "";
      return;
    }

    const res = await pagefind.search(query);
    const data = await Promise.all(res.results.map(r => r.data()));

    results.innerHTML = data.map(item => `
      <a href="${item.url}" class="result-item">
        <div class="title">${item.meta.title}</div>
        <div class="excerpt">${item.excerpt}</div>
      </a>
    `).join("");
  });
});
</script>

<style>

/* ================= NAV BASE ================= */
nav {
  z-index: 9999;
  position: relative;
  font-family: var(--font-brand);
  font-weight: 500;
  margin-bottom: 3.5rem;

  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 2.5rem 5rem;
}

/* ================= LEFT ================= */
.site-title {
  display: flex;
  gap: 0.6rem;
  align-items: center;
  font-size: var(--text-lg);
  color: var(--gray-0);
  text-decoration: none;
}

/* ================= CENTER ================= */
.nav-center {
  position: relative;
  display: flex;
  justify-content: center;
}

/* ================= NAV PILL ================= */
.nav-items {
  list-style: none;
  margin: 0;

  display: flex;
  align-items: center;
  gap: 0.3rem;

  padding: 0.5rem 0.6rem;
  border-radius: 999px;

  background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
  box-shadow: var(--shadow-md);

  position: relative;
  overflow: hidden;
  isolation: isolate;
}

.nav-items::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: 999px;
  background: var(--gradient-stroke);
  z-index: -1;
  pointer-events: none;
}

/* ================= LINKS ================= */
.link {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  padding: 0.5rem 1rem;
  border-radius: 999px;

  font-size: var(--text-sm);
  color: var(--gray-300);

  background: transparent;
  border: none;
  cursor: pointer;

  text-decoration: none;

  transition:
    color var(--theme-transition),
    background-color var(--theme-transition);
}

.link:hover {
  color: var(--gray-100);
  background: var(--accent-subtle-overlay);
}

.link[aria-current='page'] {
  background: var(--accent-regular);
  color: var(--accent-text-over);
}

/* ================= SEARCH ================= */
.search-item {
  display: flex;
  align-items: center;
}

.search-inline {
  display: flex;
  align-items: center;
  gap: 0.4rem;

  width: 0;
  opacity: 0;
  overflow: hidden;

  transform: scaleX(0.85);
  transform-origin: left;

  transition:
    width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.2s ease,
    transform 0.25s ease;
}

nav.search-open .search-inline {
  width: 260px;
  opacity: 1;
  transform: scaleX(1);
}

nav.search-open .search-trigger {
  width: 0;
  padding: 0;
  margin: 0;
  overflow: hidden;
}

/* ================= INPUT ================= */
#search-input {
  width: 100%;
  padding: 0.45rem 0.9rem;

  border-radius: 999px;
  border: none;

  background: transparent;
  color: var(--gray-0);

  font-size: 0.85rem;
  outline: none;
}

#search-input::placeholder {
  color: var(--gray-500);
}

/* ================= RESULTS ================= */
/* ================= RESULTS ================= */
#search-results {
  position: absolute;
  top: calc(100% + 14px);
  left: 50%;
  transform: translateX(-50%);

  width: 360px;
  max-height: 380px;
  overflow-y: auto;

  display: flex;
  flex-direction: column;
  gap: 0.5rem;

  padding: 0.5rem;

  border-radius: 14px;
  border: 1px solid var(--gray-800);

  background: var(--gray-999);
  box-shadow: var(--shadow-lg);

  z-index: 9999;
}

/* ================= CARD ================= */
.result-item {
  display: block;

  padding: 0.8rem 0.9rem;
  border-radius: 10px;

  /* clean light card */
  background: var(--gray-900);
  border: 1px solid var(--gray-800);

  text-decoration: none;
  color: var(--gray-100);

  transition: background 0.2s ease, transform 0.15s ease;
}

/* 🔥 SIMPLE DARK HOVER (what you wanted) */
.result-item:hover {
  background: var(--gray-800); /* darker */
  transform: translateY(-1px);
}

/* ================= TITLE ================= */
.title {
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--gray-0);
}

/* ================= EXCERPT ================= */
.excerpt {
  font-size: 0.78rem;
  color: var(--gray-400);
  margin-top: 4px;
  line-height: 1.4;
}

.result-item::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    120deg,
    transparent,
    rgba(255,255,255,0.06),
    transparent
  );
  opacity: 0;
  transition: opacity 0.3s;
}



/* ================= SCROLLBAR (nice touch) ================= */
#search-results::-webkit-scrollbar {
  width: 6px;
}

#search-results::-webkit-scrollbar-thumb {
  background: var(--gray-600);
  border-radius: 10px;
}

#search-results::-webkit-scrollbar-track {
  background: transparent;
}
/* ================= CLOSE ================= */
.search-close {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 26px;
  height: 26px;

  border-radius: 50%;
  border: none;

  background: var(--gray-800);
  color: var(--gray-300);

  cursor: pointer;
  transition: all 0.2s ease;
}

.search-close:hover {
  background: var(--accent-regular);
  color: white;
}

/* ================= RIGHT ================= */
.menu-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

/* ================= MOBILE ================= */
@media (max-width: 768px) {
  nav {
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.5rem;
  }

  .menu-footer {
    justify-content: center;
  }

  nav.search-open .search-inline {
    width: 100%;
  }

  #search-results {
    width: 100%;
    left: 0;
    transform: none;
  }
}

/* CLEAN FIXES */
.nav-center,
.search-item {
  background: transparent;
}

.nav-items {
  background: radial-gradient(var(--gray-900), var(--gray-800) 150%);
}

#search-results:empty {
  display: none;
}

.search-trigger {
  transition: opacity 0.15s ease;
}

nav.search-open .search-trigger {
  opacity: 0;
}

/* ================= SOCIAL ICON LINKS ================= */
.socials {
  display: flex;
  gap: 0.5rem;
  margin-right: 0.5rem;
}

/* base button */
.social {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 34px;
  height: 34px;

  border-radius: 50%;
  text-decoration: none;

  /* 👇 FIXED FOR LIGHT MODE */
  background: var(--gray-900);
  border: 1px solid var(--gray-800);

  color: var(--gray-300);

  transition: all 0.1s ease;
}

/* icon inside */
.social svg {
  width: 16px;
  height: 16px;
  opacity: 0.85;
  transition: 0.2s;
}

/* hover */
.social:hover {
  background: var(--accent-regular);
  color: var(--accent-text-over);

  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}

/* icon hover pop */
.social:hover svg {
  opacity: 1;
  transform: scale(1.1);
}

/* ================= LIGHT MODE TWEAK ================= */
:root:not(.theme-dark) .social {
  background: white;
  border: 1px solid var(--gray-800);
  color: var(--gray-500);
}

:root:not(.theme-dark) .social:hover {
  background: var(--accent-regular);
  color: white;
}

</style>